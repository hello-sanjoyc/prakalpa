{"level":30,"time":1767801961952,"pid":14867,"hostname":"Sanjoys-MacBook-Pro.local","msg":"Executing (default): SELECT\n                m.*,\n                u.id AS user_id,\n                u.username AS user_username,\n                u.email AS user_email,\n                u.department_id AS user_department_id,\n                GROUP_CONCAT(DISTINCT r.name) AS role_names,\n                GROUP_CONCAT(DISTINCT r.slug) AS role_slugs,\n                d.name AS department_name\n            FROM members m\n            LEFT JOIN users u ON u.member_id = m.id AND u.deleted_at IS NULL\n            LEFT JOIN user_roles ur ON ur.user_id = u.id\n            LEFT JOIN roles r ON r.id = ur.role_id \n            LEFT JOIN departments d ON d.id = m.department_id\n            GROUP BY m.id, u.id\n            ORDER BY m.full_name ASC"}
