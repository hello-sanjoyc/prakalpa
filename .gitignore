########################################
# 🔐 ENV FILES (CRITICAL)
########################################
.env
.env.*
!.env.example

########################################
# 📦 DEPENDENCIES
########################################
node_modules/
**/node_modules/

########################################
# 🏗 BUILD OUTPUTS
########################################
dist/
build/
**/dist/
**/build/

########################################
# 🧾 LOGS
########################################
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

########################################
# 🗂 RUNTIME / CACHE
########################################
.cache/
.tmp/
temp/

########################################
# 📁 UPLOADS (backend)
########################################
backend/upload/*
!backend/upload/.gitkeep

########################################
# 🗄 DATABASE FILES (if local db used)
########################################
backend/db/*.sqlite
backend/db/*.db

########################################
# 🧠 PM2
########################################
.pm2/

########################################
# 🧰 OS FILES
########################################
.DS_Store
Thumbs.db

########################################
# 💻 IDE / EDITOR
########################################
.vscode/
.idea/

########################################
# 🔒 CERTS / KEYS
########################################
*.pem
*.key
*.crt

########################################
# 🚫 MISC
########################################
*.pid
*.seed
*.tgz